# ──────────────────────────────────────────────────────────────
# Client config (safe to be public — baked into the static build)
# The Supabase anon key is PUBLIC by design and protected by RLS.
# These have working defaults in src/lib/supabase.js; override here
# only if you point the app at a different Supabase project.
# ──────────────────────────────────────────────────────────────
VITE_SUPABASE_URL=https://kibqjztozokohqmhqqqf.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# ──────────────────────────────────────────────────────────────
# SECRET — DO NOT put this in any VITE_ var or client code.
# The Gemini key lives ONLY as a Supabase Edge Function secret:
#   supabase secrets set GEMINI_KEY=AIza...
# See supabase/functions/gemini-scan/  and  README.md
# ──────────────────────────────────────────────────────────────
